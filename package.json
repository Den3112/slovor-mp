{
  "name": "slovor-mp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS=\"--max-old-space-size=4096\" next build",
    "start": "next start",
    "clean": "rimraf .next node_modules",
    "clean-next": "rimraf .next",
    "lint": "cross-env NODE_ENV=development eslint src --cache",
    "lint:fix": "eslint src --fix --cache",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src --cache",
    "format:check": "prettier --check src --cache",
    "check:circular": "madge --circular --extensions ts,tsx src --ts-config ./tsconfig.json --exclude '.next|node_modules|public|.github|.agent'",
    "setup:husky": "husky",
    "db:info": "node scripts/db-info.js",
    "db:clear": "node scripts/clear-listings.js",
    "db:seed": "node scripts/seed-with-real-images.js",
    "db:reset": "npm-run-all db:clear db:seed",
    "db:fix-advisor": "node scripts/apply-advisor-fix.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:visual": "playwright test src/e2e/visual.spec.ts",
    "test:visual:update": "playwright test src/e2e/visual.spec.ts --update-snapshots",
    "verify": "npm-run-all --parallel lint type-check check:circular && npm run build",
    "fix": "npm-run-all format lint:fix",
    "validate": "npm-run-all --parallel lint type-check check:circular",
    "knip": "knip",
    "analyze": "cross-env ANALYZE=true npm run build",
    "precommit": "lint-staged",
    "prepare": "husky",
    "audit:quick": "squirrel audit https://slovor-mp.vercel.app -C quick --format llm",
    "audit:surface": "squirrel audit https://slovor-mp.vercel.app -C surface --format llm",
    "audit:full": "squirrel audit https://slovor-mp.vercel.app -C full --format llm",
    "storybook": "cross-env STORYBOOK=true NEXT_PUBLIC_STORYBOOK=true storybook dev -p 6006",
    "build-storybook": "cross-env STORYBOOK=true NEXT_PUBLIC_STORYBOOK=true storybook build"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@formatjs/intl-localematcher": "0.8.1",
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.2",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-visually-hidden": "1.2.4",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.3",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.36.3",
    "@vercel/analytics": "1.6.1",
    "@vitest/ui": "^4.1.0",
    "axe-playwright": "^2.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "4.1.0",
    "dotenv": "^17.0.3",
    "embla-carousel-react": "8.6.0",
    "framer-motion": "^12.38.0",
    "i18next": "^25.8.0",
    "i18next-resources-to-backend": "^1.2.1",
    "idb": "^8.0.3",
    "lucide-react": "0.475.0",
    "negotiator": "1.0.0",
    "next": "16.2.1",
    "next-themes": "0.4.6",
    "nuqs": "^2.8.9",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.3",
    "recharts": "^3.7.0",
    "server-only": "^0.0.1",
    "sharp": "0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^20.2.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "1.0.7",
    "uuid": "^13.0.0",
    "vaul": "1.1.2",
    "xss": "^1.0.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.1.6",
    "@playwright/test": "^1.58.1",
    "@storybook/addon-a11y": "^10.2.3",
    "@storybook/addon-vitest": "^10.2.3",
    "@storybook/nextjs-vite": "^10.2.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.1",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "5.1.2",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.21.0",
    "eslint-config-next": "16.2.1",
    "eslint-plugin-storybook": "^10.2.3",
    "typescript-eslint": "^8.24.1",
    "@eslint/js": "^9.21.0",
    "happy-dom": "20.3.7",
    "husky": "9.1.7",
    "jsdom": "^26.0.0",
    "knip": "^5.83.0",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.58.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.2",
    "storybook": "^10.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=9.0.0"
  },
  "volta": {
    "node": "20.18.3"
  },
  "overrides": {
    "flatted": "3.4.2"
  }
}
