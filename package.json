{
  "name": "slovor-mp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "quality:lint": "eslint .",
    "lint": "npm run quality:lint",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run quality:lint && npm run type-check && npm run check:circular && npm run build",
    "precommit": "npm run quality:lint && npm run type-check",
    "clean": "rm -rf .next node_modules",
    "db:info": "node scripts/db-info.js",
    "db:clear": "node scripts/clear-listings.js",
    "db:seed": "node scripts/seed-with-real-images.js",
    "db:reset": "npm run db:clear && npm run db:seed",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:visual": "./scripts/check-server.sh && playwright test e2e/visual.spec.ts",
    "test:visual:update": "./scripts/check-server.sh && playwright test e2e/visual.spec.ts --update-snapshots",
    "test:e2e": "./scripts/check-server.sh && playwright test",
    "check:circular": "madge --circular --extensions ts,tsx . --exclude '.next|node_modules|public|.github|.agent'",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.8.0",
    "@headlessui/react": "^2.2.0",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-visually-hidden": "1.2.4",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.48.1",
    "@vercel/analytics": "1.6.1",
    "@vercel/speed-insights": "1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "4.1.0",
    "dotenv": "^17.0.3",
    "embla-carousel-react": "8.6.0",
    "framer-motion": "^12.29.0",
    "i18next": "^25.8.0",
    "i18next-resources-to-backend": "^1.2.1",
    "lucide-react": "^0.563.0",
    "negotiator": "^1.0.0",
    "next-themes": "0.4.6",
    "pg": "^8.13.1",
    "react-i18next": "^16.5.3",
    "sonner": "2.0.7",
    "stripe": "^20.2.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "1.0.7",
    "vaul": "1.1.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.0",
    "@eslint/eslintrc": "^3.3.3",
    "@playwright/test": "1.57.0",
    "@storybook/addon-a11y": "^10.2.3",
    "@storybook/addon-docs": "^10.2.3",
    "@storybook/addon-onboarding": "^10.2.3",
    "@storybook/addon-vitest": "^10.2.3",
    "@storybook/nextjs-vite": "^10.2.3",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.1",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "5.1.2",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-istanbul": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "autoprefixer": "^10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "^15.1.6",
    "eslint-plugin-storybook": "^10.2.3",
    "happy-dom": "20.3.7",
    "husky": "9.1.7",
    "jsdom": "27.4.0",
    "madge": "^8.0.0",
    "next": "^16.1.4",
    "playwright": "^1.58.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "storybook": "^10.2.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "volta": {
    "node": "22.22.0"
  }
}
