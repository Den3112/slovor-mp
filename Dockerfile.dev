# ===========================================
# Development Dockerfile for Slovor Marketplace
# Optimized for local development with live reload
# ===========================================

FROM node:22-alpine

# libc6-compat is needed for Alpine compatibility
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Set environment variables for development
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1

# Install dependencies first (better caching)
# Note: We expect node_modules to be mounted as a volume or installed during build
COPY package.json package-lock.json* ./

# Install dependencies with legacy-peer-deps
RUN npm install --legacy-peer-deps

# The rest of the files will be mounted via volumes in docker-compose
# but we copy them anyway for a fallback
COPY . .

# Expose the development port
EXPOSE 3000

# Start the development server
CMD ["npm", "run", "dev"]
