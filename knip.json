{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "app/[locale]/**/page.tsx",
    "app/[locale]/**/layout.tsx",
    "app/api/**/route.ts"
  ],
  "project": [
    "**/*.{ts,tsx}"
  ],
  "ignore": [
    "node_modules",
    ".next",
    "public",
    "scripts",
    "e2e",
    ".agent",
    "components/ui/v0/**",
    "lib/types/database.ts"
  ],
  "ignoreDependencies": []
}
