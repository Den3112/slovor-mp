{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "app/[locale]/**/page.tsx",
    "app/[locale]/**/layout.tsx",
    "app/api/**/route.ts",
    "middleware.ts"
  ],
  "project": ["**/*.{ts,tsx}"],
  "ignore": [
    "node_modules",
    ".next",
    "public",
    "scripts",
    "e2e",
    ".agent",
    "components/ui/v0/**",
    "lib/types/database.ts"
  ],
  "ignoreDependencies": [
    "lucide-react",
    "framer-motion",
    "sonner",
    "npm-run-all",
    "cross-env",
    "@next/bundle-analyzer",
    "knip"
  ]
}
