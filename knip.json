{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/app/[lang]/**/page.tsx",
    "src/app/[lang]/**/layout.tsx",
    "src/app/api/**/route.ts"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "node_modules",
    ".next",
    "public",
    "scripts",
    ".agent",
    "src/components/ui/v0/**",
    "src/lib/types/database.ts"
  ],
  "ignoreDependencies": []
}
