# Slovor Marketplace - Environment Variables
# Copy this file to .env.local for local development

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Optional: Different Supabase projects for environments
# Development: Use local Supabase or dedicated dev project
# Production: Use production Supabase project

# Example for multiple environments:
# DEV:  NEXT_PUBLIC_SUPABASE_URL=https://dev-project.supabase.co
# PROD: NEXT_PUBLIC_SUPABASE_URL=https://prod-project.supabase.co
