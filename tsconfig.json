{
  "compilerOptions": {
    // JavaScript Support
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    // Type Checking - STRICT MODE
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    // Additional Checks
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    // Module Resolution
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    // Emit
    "noEmit": true,
    "jsx": "react-jsx",
    "incremental": true,
    // Next.js
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@i18n/*": ["./packages/i18n/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next_creator/types/**/*.ts",
    ".next_creator/dev/types/**/*.ts",
    ".next_final/types/**/*.ts",
    ".next_final/dev/types/**/*.ts",
    ".next_slovor/types/**/*.ts",
    ".next_slovor/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    ".next_creator",
    ".next_final",
    ".next_slovor",
    "e2e",
    "playwright.config.ts"
  ]
}
