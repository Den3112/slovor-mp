# Dependencies
node_modules
.pnp
.pnp.js

# Testing
coverage
__tests__
*.test.js
*.test.ts
*.spec.js
*.spec.ts
e2e
playwright-report
test-results

# Build outputs
.next
out
build
dist

# Development
.git
.gitignore
.github
.vscode
.idea
*.swp
*.swo

# Docker
Dockerfile*
docker-compose*.yml
.docker
.dockerignore

# Environment files (except example)
.env
.env.*
!.env.example

# Documentation
README.md
CHANGELOG.md
LICENSE
docs
*.md

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# OS files
.DS_Store
Thumbs.db

# IDE
*.sublime-*
.editorconfig

# TypeScript cache
*.tsbuildinfo
tsconfig.tsbuildinfo

# Husky
.husky

# Misc
*.log
*.tmp
*.temp
